# Elasticsearch Configuration
ELASTICSEARCH_URL=http://localhost:9200

# LLM Provider Configuration
LLM_PROVIDER=gemini # or openai, anthropic
GEMINI_API_KEY=your_gemini_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Geopolitics & News APIs (Aggregators)
# Choose one of the following based on your preference
NEWSDATA_API_KEY=your_newsdata_api_key_here
GNEWS_API_KEY=your_gnews_api_key_here
NEWSAPI_KEY=your_newsapi_org_key_here
MEDIASTACK_API_KEY=your_mediastack_api_key_here

# Financial & Economic Data APIs
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_api_key_here
FRED_API_KEY=your_fred_api_key_here
TWELVE_DATA_API_KEY=your_twelve_data_api_key_here

# RSS Feeds (No authentication required, using robust defaults)
# Military & Defense
RSS_WAR_ON_THE_ROCKS=https://warontherocks.com/feed/
RSS_LONG_WAR_JOURNAL=https://www.longwarjournal.org/feed
